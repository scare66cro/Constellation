# ─── Node / npm ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
.npm/

# ─── Build outputs ───────────────────────────────────────────────────────
build/
dist/
out/
.svelte-kit/
.vite/
.turbo/
.next/
.nuxt/
.cache/
*.tsbuildinfo

# Firmware build artifacts
Nova_Firmware/build/
orbit-simulator/build/
qemu-constellation/build/
**/*.elf
**/*.bin
**/*.hex
**/*.map
**/*.o
**/*.d
**/*.a
**/*.lst

# ─── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Editor / OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
*.iml
.vscode/*.log

# Keep .vscode shared settings but ignore user-local
.vscode/.ropeproject/
.vscode/chrome/
.vscode/ipch/

# ─── Logs / runtime ──────────────────────────────────────────────────────
*.log
logs/
.constellation-pids
.tmp-*.json
constellation-ui/server/.sim-config/
constellation-ui/__azurite_db_*
constellation-ui/test-results/
constellation-ui/playwright-report/

# ─── Secrets / local config ──────────────────────────────────────────────
.env
.env.local
.env.*.local
**/local.settings.json
**/dev_secrets.py
**/.terraform/
*.pem
*.key

# ─── Archives / packaged artifacts ───────────────────────────────────────
*.zip
*.tar.gz
*.tgz

# ─── Azure Functions ─────────────────────────────────────────────────────
Azure/AgristarCloud/.azure/
Azure/AgristarCloud/bin/
Azure/AgristarCloud/obj/

# ─── QEMU / runtime simulator data ───────────────────────────────────────
qemu-constellation/*.qcow2
qemu-constellation/*.raw

# ─── Generated proto bundles (large, regenerable) ────────────────────────
# Keep proto/ source but ignore generated/ since it's reproducible
generated/

# Local helper scripts inside proto/ (e.g. _regen.sh that wraps the
# canonical generate.ps1 to work around PowerShell native-stderr quirks).
# Convention: anything in proto/ starting with `_` is dev-local.
proto/_*

# ─── Deploy / runtime artifacts (large, regenerable) ─────────────────────
constellation-ui/server/deploy/
constellation-ui/server/data/*.db
constellation-ui/server/data/*.db-wal
constellation-ui/server/data/*.db-shm
constellation-ui/build/

# ─── Legacy reference firmware (huge & not built) ────────────────────────
# Keep top-level READMEs but ignore the bulk of legacy code
"Mini_IO legacy refference only firmware/"
GRC/


# Generated by Flash-LP.ps1 � carries the per-flash version string
Nova_Firmware/lp_am2434/lp_version_injected.h

Nova_Firmware/lp_am2434/ti-arm-clang/.last-build-role.json

# Local-only scratch memory notes (per-machine, not for git history)
memories/

# ─── Claude Code / agent harness ─────────────────────────────────────────
# Per-machine assistant session state — worktrees, settings.local.json,
# scheduled task locks. Never goes in git history.
.claude/

# ─── Built firmware OTA bundles ──────────────────────────────────────────
# Regenerable via Nova_Firmware/lp_am2434/Build-Cfu.ps1 + scripts/Build-CfuBundle.ps1.
# Bundles are large (~700 KB each) and rotate with every firmware bump.
firmware-bundles/

# ─── Runtime tool output ─────────────────────────────────────────────────
nohup.out
flash_log.txt

# ─── Bench helper scripts that embed credentials ────────────────────────
# These wrap ssh/scp to the rpi5 bench with the SSH password hard-coded.
# DO NOT COMMIT — they would leak the bench credential into git history.
# If you want a shareable version, switch to ssh key auth (or read the
# pw from $env:RPI_BENCH_SSHPASS) before unignoring.
_get_bridge_log.sh
_restart_bridge.sh

# ─── Universal backup-file pattern ───────────────────────────────────────
# Catches *.bak (one-off "before-this-change" snapshots) and the
# *.bak.pre-<tag> convention used in Nova_Firmware/lp_am2434 for
# pre-rework checkpoints (e.g. example.syscfg.bak.pre-enet,
# main.c.bak.pre-enet, makefile.bak.pre-enet).
*.bak
*.bak.*
